# Öffentliche Basis-URL (ohne Slash am Ende) — für Stripe Redirects
# Produktion z. B.: https://bavaria-peptides.com
# Muss zur Dev-URL passen (Standard: Port 43000, siehe npm run dev in package.json)
NEXT_PUBLIC_SITE_URL=http://localhost:43000

# Optional: Suchmaschinen-Site-Verifikation (öffentliche Meta-Tags)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=…
# NEXT_PUBLIC_YANDEX_VERIFICATION=…
# NEXT_PUBLIC_BING_SITE_VERIFICATION=…

# Stripe (Server only — nie NEXT_PUBLIC_*). Echten Key nur in .env.local setzen, nicht committen.
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_…

# Optional: institutionelle Anfragen per POST (Formspree, Getform, …)
# NEXT_PUBLIC_INSTITUTIONAL_INQUIRY_ACTION=https://...

# Optional: Bestätigungs-E-Mails (Kontaktformular + Anfrage-Ack an Absender)
# https://resend.com/api-keys — Absenderdomain in Resend verifizieren
# RESEND_API_KEY=re_…
# RESEND_FROM=Bavaria Peptides <onboarding@resend.dev>
