# Öffentliche Basis-URL (ohne Slash am Ende) — für Links in E-Mails
# Produktion z. B.: https://www.bavaria-peptides.com
# Muss zur Dev-URL passen (Standard: Port 43000, siehe npm run dev in package.json)
NEXT_PUBLIC_SITE_URL=http://localhost:43000

# Optional: Suchmaschinen-Site-Verifikation (öffentliche Meta-Tags)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=…
# NEXT_PUBLIC_YANDEX_VERIFICATION=…
# NEXT_PUBLIC_BING_SITE_VERIFICATION=…

# Banküberweisung (Checkout) — nur serverseitig, nie NEXT_PUBLIC_*
BANK_ACCOUNT_HOLDER=Bavaria Peptides
BANK_IBAN=DE00 0000 0000 0000 0000 00
# Optional, empfohlen für SEPA
BANK_BIC=ABCDEFGHXXX
# Optional
# BANK_INSTITUTION=Musterbank AG
# Zusatztext in der Bestell-E-Mail (z. B. Fristen)
# BANK_PAYMENT_NOTE=Bitte überweisen Sie innerhalb von 7 Werktagen.

# Bestätigungs-E-Mails (Kontaktformular, Bank-Bestellung, …) — SMTP-Versand
# Empfohlen: Zoho Mail (eigenes Postfach info@bavaria-peptides.com).
# Für Zoho Free / privates Konto: smtp.zoho.eu
# Für Zoho Mail Lite / Workplace (Paid): smtppro.zoho.eu
SMTP_HOST=smtp.zoho.eu
# 465 (SSL, empfohlen) oder 587 (STARTTLS)
SMTP_PORT=465
# optional — wird sonst aus Port abgeleitet: "true" bei 465, "false" bei 587
# SMTP_SECURE=true
# Volle Absender-Adresse (= eingeloggter Account)
SMTP_USER=info@bavaria-peptides.com
# App-spezifisches Passwort aus Zoho (Sicherheit → App-Passwörter), NICHT das Login-Passwort
SMTP_PASS=__app_password__
# Optional: Anzeige-Absender (Display-Name + Mail). Wenn leer: "<Brand> <SMTP_USER>"
SMTP_FROM=Bavaria Peptides <info@bavaria-peptides.com>

# Optional: institutionelle Anfragen per POST (Formspree, Getform, …)
# NEXT_PUBLIC_INSTITUTIONAL_INQUIRY_ACTION=https://...

# ----------------------------------------------------------------------------
# Datenbank: Supabase (Schema `shop`)
# ----------------------------------------------------------------------------
# Aus Supabase Dashboard → Project Settings → Data API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Aus Supabase Dashboard → Project Settings → API Keys → service_role.
# NUR auf dem Server verwenden, niemals an den Browser geben (kein NEXT_PUBLIC_*).
SUPABASE_SERVICE_ROLE_KEY=__service_role_key__

# ----------------------------------------------------------------------------
# Admin-Bereich (/admin)
# ----------------------------------------------------------------------------
# Wenn leer, wird beim ersten Start automatisch ein Geheimnis unter
# .data/admin/secret angelegt. Auf dem VPS empfehlenswert: stattdessen hier
# einen festen 64+-stelligen Wert setzen (z. B. `openssl rand -hex 48`).
# ADMIN_SESSION_SECRET=…

# Optional: alternativer Pfad für das Session-Secret (Default .data/admin/).
# ADMIN_DATA_DIR=/var/lib/bpeditsshop/admin
